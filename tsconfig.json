{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/public/*": [
        "./public/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/api/*": [
        "./src/app/api/*"
      ],
      "@/config/*": [
        "./src/app/config/*"
      ],
      "@/auth": [
        "./src/lib/auth.ts"
      ],
      "@/db/*": [
        "./src/db/*"
      ],
      "@/data/*": [
        "./src/data/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/content/*": [
        "./src/content/*"
      ],
      "@/context/*": [
        "./src/context/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/services/*": [
        "./src/services/*"
      ],
      "@/store/*": [
        "./src/store/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
